# PostgreSQL (used by docker compose)
POSTGRES_USER=recon
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ledger_db

# Backend
# Required everywhere - no SQLite fallback (every environment runs Postgres).
# For docker compose this is set automatically via POSTGRES_* above; for
# local dev without Docker, run `docker compose up -d db` and point at it:
DATABASE_URL=postgresql+psycopg://recon:change-me@localhost:5432/ledger_db
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Auth (IMPORTANT: change these before exposing publicly)
# SECRET_KEY signs login tokens - set to a long random string in production.
SECRET_KEY=change-me-to-a-long-random-secret
# Seed admin account, created on first startup only.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# Google Sign-In (Cross Way Ledger Web Client in Google Cloud) - same value
# as the frontend's VITE_GOOGLE_CLIENT_ID, so the backend can verify the ID
# token was issued for this app.
GOOGLE_CLIENT_ID=
GOOGLE_WORKSPACE_DOMAIN=crosswaymtc.org

# Production/staging only (docker-compose.prod.yml) - see docs/DEPLOYMENT.md.
# DOMAIN is the public hostname Caddy requests a TLS cert for.
# IMAGE_TAG is set per-deploy by CI to the git SHA being promoted; leave
# unset (defaults to "latest") for a manual deploy.
# DOMAIN=ledger.crosswaymtc.org
# IMAGE_TAG=
