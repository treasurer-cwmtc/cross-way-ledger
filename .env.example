# PostgreSQL (used by docker compose)
POSTGRES_USER=recon
POSTGRES_PASSWORD=change-me
POSTGRES_DB=recon

# Backend
# For docker compose this is set automatically; for local dev without Docker
# leave it unset to use a local SQLite file (sqlite:///./recon.db).
# DATABASE_URL=postgresql+psycopg://recon:change-me@localhost:5432/recon
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Auth (IMPORTANT: change these before exposing publicly)
# SECRET_KEY signs login tokens - set to a long random string in production.
SECRET_KEY=change-me-to-a-long-random-secret
# Seed admin account, created on first startup only.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# Google Sign-In (Cross Way Ledger Web Client in Google Cloud) - same value
# as the frontend's VITE_GOOGLE_CLIENT_ID, so the backend can verify the ID
# token was issued for this app.
GOOGLE_CLIENT_ID=
GOOGLE_WORKSPACE_DOMAIN=crosswaymtc.org
